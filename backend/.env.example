FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key

# Local SQLite (default when DATABASE_URL is unset):
# DATABASE_URL=sqlite:///sams.db

# Production — Neon Postgres (copy from Neon dashboard → Connection string):
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

UPLOAD_FOLDER=uploads/faces
FACE_TOLERANCE=0.6

# Comma-separated extra CORS origins (local dev origins are always allowed):
# CORS_ORIGINS=https://your-app.netlify.app

# Netlify only — proxies /api to Render (set in Netlify dashboard, not Flask):
# RENDER_API_URL=https://your-service.onrender.com
